\itemize{
\item \link{DiscreteMatrix}, \link{ContinuousMatrix} — the matrix classes accepted by
this command.
\item \code{\link[=create_matrix]{create_matrix()}} — recommended way to create matrix objects.
\item \link{TreeAnalysis} — creates this command automatically when \verb{$data} is
assigned.
}
}
