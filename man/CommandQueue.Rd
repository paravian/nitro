\item \code{\link[=as.character.CommandQueue]{as.character.CommandQueue()}} — renders all queued commands to a
character vector.
\item \code{\link[=execute_analysis]{execute_analysis()}} — checks \verb{$is_resolved} before executing the
queue.
}
}
